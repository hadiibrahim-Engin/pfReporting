{% from 'partials/_macros.html.j2' import badge %}
<section>
    <h2>(N-1)-Kontingenzanalyse</h2>
    <div class="section-toolbar">
        <span class="grenzwert-info">
            Max. Auslastung: {{ n1cfg.max_loading_pct }}% /
            Spannung: {{ n1cfg.min_voltage_pu }}–{{ n1cfg.max_voltage_pu }} p.u.
        </span>
        <div class="toolbar-right">
            <button class="filter-btn">Nur Auffälligkeiten</button>
        </div>
    </div>
    <div class="table-scroll">
        <table>
            <thead>
                <tr>
                    <th data-sort="text">Ausfallelement</th>
                    <th>Typ</th>
                    <th>Konv.</th>
                    <th data-sort="num">Max. Auslastung</th>
                    <th data-sort="num">Min. Spannung</th>
                    <th data-sort="num">Max. Spannung</th>
                    <th>Verletzungen</th>
                    <th>Bewertung</th>
                </tr>
            </thead>
            <tbody>
                {% for r in n1 %}
                <tr>
                    <td>{{ r.outage_element }}</td>
                    <td>{{ r.type }}</td>
                    <td>
                        {% if r.converged %}
                            Ja
                        {% else %}
                            <span class="badge-verletzung">Nein</span>
                        {% endif %}
                    </td>
                    <td class="num">
                        {{ "%.1f"|format(r.max_loading_pct) }}%<br>
                        <small>({{ r.max_loading_element }})</small>
                    </td>
                    <td class="num">
                        {{ "%.4f"|format(r.min_voltage_pu) }}<br>
                        <small>({{ r.min_voltage_node }})</small>
                    </td>
                    <td class="num">
                        {{ "%.4f"|format(r.max_voltage_pu) }}<br>
                        <small>({{ r.max_voltage_node }})</small>
                    </td>
                    <td class="verletzungen-zelle">
                        {% if r.violations %}
                            {{ r.violations | join('<br>') | safe }}
                        {% else %}
                            ✓
                        {% endif %}
                    </td>
                    <td>{{ badge(r.status) }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
