{% from 'partials/_macros.html.j2' import badge, loading_bar %}
<section>
    <h2>Thermische Auslastung</h2>
    <div class="section-toolbar">
        <span class="grenzwert-info">
            Warnung ab {{ tcfg.warning_pct }}% /
            Kritisch ab {{ tcfg.violation_pct }}%
        </span>
        <div class="toolbar-right">
            <button class="filter-btn">Nur Auffälligkeiten</button>
        </div>
    </div>
    <table>
        <thead>
            <tr>
                <th data-sort="text">Element</th>
                <th data-sort="text">Typ</th>
                <th data-sort="num">Auslastung</th>
                <th data-sort="num">I [kA]</th>
                <th data-sort="num">I_nenn [kA]</th>
                <th>Bewertung</th>
            </tr>
        </thead>
        <tbody>
            {% for r in loading %}
            <tr>
                <td>{{ r.name }}</td>
                <td>{{ r.type }}</td>
                <td class="num">{{ loading_bar(r.loading_pct, r.status) }}</td>
                <td class="num">{{ "%.3f"|format(r.i_ka) }}</td>
                <td class="num">{{ "%.3f"|format(r.i_nenn_ka) }}</td>
                <td>{{ badge(r.status) }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {% if thermal_hm_data %}
    <div class="hm-toggle-row">
        <button class="hm-toggle-btn"
                data-target="hm-thermal"
                data-label-open="Auslastungs-Heatmap anzeigen"
                data-label-close="Auslastungs-Heatmap ausblenden">
            Auslastungs-Heatmap anzeigen
        </button>
    </div>
    <div id="hm-thermal" class="hm-panel" style="display:none;"
         data-hm="{{ thermal_hm_data | tojson | e }}">
        <div class="hm-controls-bar">
            <button class="hm-select-btn" data-mode="critical">Nur auffällige</button>
            <button class="hm-select-btn" data-mode="all">Alle</button>
            <button class="hm-select-btn" data-mode="none">Keine</button>
            <span class="hm-info"></span>
        </div>
        <div class="hm-elem-selector"></div>
        <div class="hm-render-area"></div>
    </div>
    {% endif %}
</section>
