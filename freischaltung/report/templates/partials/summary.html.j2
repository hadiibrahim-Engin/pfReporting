<section class="zusammenfassung">
    <h2>Zusammenfassung</h2>
    <p>{{ overall.summary_text | safe }}</p>
    <div class="kpi-row">
        <div class="kpi">
            <div class="kpi-wert">{{ overall.total_nodes }}</div>
            <div class="kpi-label">Knoten geprüft</div>
        </div>
        <div class="kpi">
            <div class="kpi-wert">{{ overall.total_elements }}</div>
            <div class="kpi-label">Betriebsmittel geprüft</div>
        </div>
        <div class="kpi">
            <div class="kpi-wert">{{ overall.total_n1 }}</div>
            <div class="kpi-label">N-1-Fälle geprüft</div>
        </div>
        <div class="kpi {% if overall.total_violations > 0 %}kpi-highlight{% endif %}">
            <div class="kpi-wert">{{ overall.total_violations }}</div>
            <div class="kpi-label">Verletzungen gesamt</div>
        </div>
    </div>
</section>
