<section>
    <h2>Freigeschaltete Betriebsmittel</h2>
    {% if switched %}
    <table>
        <thead>
            <tr>
                <th data-sort="text">Name</th>
                <th>Typ</th>
                <th>Status vorher</th>
                <th>Status Bewertung</th>
            </tr>
        </thead>
        <tbody>
            {% for el in switched %}
            <tr>
                <td><strong>{{ el.name }}</strong></td>
                <td>{{ el.type }}</td>
                <td>{{ el.status_before }}</td>
                <td><span class="badge-verletzung">{{ el.status_assessment }}</span></td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <p style="color: var(--grau-600); font-size: 13px;">Keine Betriebsmittel freigeschaltet.</p>
    {% endif %}
</section>
