<section id="sec-statistics">
    <div class="section-header">
        <h2>Statistics Overview</h2>
        <button class="section-toggle" data-target="sec-statistics" title="Collapse / Expand">▾</button>
    </div>
    <div class="section-body">

        <div class="stats-overview-grid">

            {% if calc_options.run_voltage %}
            {% set v_total = voltage | length %}
            {% set v_viol = voltage | selectattr('status', 'eq', 'violation') | list | length %}
            {% set v_warn = voltage | selectattr('status', 'eq', 'warning') | list | length %}
            {% set v_vals = voltage | map(attribute='u_pu') | list %}
            {% set v_min = v_vals | min if v_vals else none %}
            {% set v_max = v_vals | max if v_vals else none %}
            {% set v_avg = (v_vals | sum / v_total) if v_total > 0 else none %}
            {% set v_worst = voltage | min(attribute='u_pu') if v_total > 0 else none %}
            <div class="stats-card">
                <div class="stats-card-title">Voltage Band</div>
                <div class="stats-metric-row"><span>Nodes</span><span class="num">{{ v_total }}</span></div>
                <div class="stats-metric-row"><span>Violations</span><span class="badge-violation">{{ v_viol }}</span></div>
                <div class="stats-metric-row"><span>Warnings</span><span class="badge-warning">{{ v_warn }}</span></div>
                {% if v_min is not none %}
                <div class="stats-metric-row">
                    <span>Min / Avg / Max</span>
                    <span class="num">{{ "%.4f"|format(v_min) }} / {{ "%.4f"|format(v_avg) }} / {{ "%.4f"|format(v_max) }} p.u.</span>
                </div>
                {% endif %}
                {% if v_worst %}
                <div class="stats-note">Worst node: <strong>{{ v_worst.node }}</strong> ({{ "%.4f"|format(v_worst.u_pu) }} p.u.)</div>
                {% endif %}
            </div>
            {% endif %}

            {% if calc_options.run_thermal %}
            {% set t_total = loading | length %}
            {% set t_viol = loading | selectattr('status', 'eq', 'violation') | list | length %}
            {% set t_warn = loading | selectattr('status', 'eq', 'warning') | list | length %}
            {% set t_vals = loading | map(attribute='loading_pct') | list %}
            {% set t_min = t_vals | min if t_vals else none %}
            {% set t_max = t_vals | max if t_vals else none %}
            {% set t_avg = (t_vals | sum / t_total) if t_total > 0 else none %}
            {% set t_worst = loading | max(attribute='loading_pct') if t_total > 0 else none %}
            <div class="stats-card">
                <div class="stats-card-title">Thermal Loading</div>
                <div class="stats-metric-row"><span>Elements</span><span class="num">{{ t_total }}</span></div>
                <div class="stats-metric-row"><span>Violations</span><span class="badge-violation">{{ t_viol }}</span></div>
                <div class="stats-metric-row"><span>Warnings</span><span class="badge-warning">{{ t_warn }}</span></div>
                {% if t_min is not none %}
                <div class="stats-metric-row">
                    <span>Min / Avg / Max</span>
                    <span class="num">{{ "%.1f"|format(t_min) }} / {{ "%.1f"|format(t_avg) }} / {{ "%.1f"|format(t_max) }} %</span>
                </div>
                {% endif %}
                {% if t_worst %}
                <div class="stats-note">Worst element: <strong>{{ t_worst.name }}</strong> ({{ "%.1f"|format(t_worst.loading_pct) }}%)</div>
                {% endif %}
            </div>
            {% endif %}

            {% if calc_options.run_n1 %}
            {% set n1_total = n1 | length %}
            {% set n1_viol = n1 | selectattr('status', 'eq', 'violation') | list | length %}
            {% set n1_conv = n1 | selectattr('converged', 'eq', true) | list | length %}
            {% set n1_rate = (n1_conv / n1_total * 100) if n1_total > 0 else none %}
            {% set n1_worst_load = n1 | max(attribute='max_loading_pct') if n1_total > 0 else none %}
            {% set n1_worst_minv = n1 | min(attribute='min_voltage_pu') if n1_total > 0 else none %}
            <div class="stats-card">
                <div class="stats-card-title">(N-1) Contingency</div>
                <div class="stats-metric-row"><span>Cases</span><span class="num">{{ n1_total }}</span></div>
                <div class="stats-metric-row"><span>Violations</span><span class="badge-violation">{{ n1_viol }}</span></div>
                {% if n1_rate is not none %}
                <div class="stats-metric-row"><span>Convergence</span><span class="num">{{ "%.1f"|format(n1_rate) }}%</span></div>
                {% endif %}
                {% if n1_worst_load %}
                <div class="stats-note">Worst loading: <strong>{{ n1_worst_load.outage_element }}</strong> ({{ "%.1f"|format(n1_worst_load.max_loading_pct) }}%)</div>
                {% endif %}
                {% if n1_worst_minv %}
                <div class="stats-note">Lowest voltage: <strong>{{ n1_worst_minv.min_voltage_node }}</strong> ({{ "%.4f"|format(n1_worst_minv.min_voltage_pu) }} p.u.)</div>
                {% endif %}
            </div>
            {% endif %}

            {% if calc_options.run_loadflow %}
            {% set loss_pct = (lf.losses_mw / lf.total_gen_mw * 100) if lf.total_gen_mw > 0 else none %}
            <div class="stats-card">
                <div class="stats-card-title">Load Flow</div>
                <div class="stats-metric-row"><span>Status</span><span class="num">{{ lf.status_text }}</span></div>
                <div class="stats-metric-row"><span>Iterations</span><span class="num">{{ lf.iterations }}</span></div>
                <div class="stats-metric-row"><span>Load / Gen</span><span class="num">{{ "%.2f"|format(lf.total_load_mw) }} / {{ "%.2f"|format(lf.total_gen_mw) }} MW</span></div>
                {% if loss_pct is not none %}
                <div class="stats-metric-row"><span>Losses</span><span class="num">{{ "%.2f"|format(lf.losses_mw) }} MW ({{ "%.2f"|format(loss_pct) }}%)</span></div>
                {% endif %}
                {% if lf.load_power_factor is not none %}
                <div class="stats-note">Load PF: <strong>{{ "%.3f"|format(lf.load_power_factor) }}</strong> · Gen PF: <strong>{{ "%.3f"|format(lf.gen_power_factor) }}</strong></div>
                {% endif %}
            </div>
            {% endif %}

            {% if calc_options.run_qds and lf.qds_steps %}
            {% set qds_total = lf.qds_steps | length %}
            {% set qds_fail = lf.qds_steps | selectattr('converged', 'eq', false) | list | length %}
            {% set qds_rate = ((qds_total - qds_fail) / qds_total * 100) if qds_total > 0 else none %}
            <div class="stats-card">
                <div class="stats-card-title">Quasi-Dynamic</div>
                <div class="stats-metric-row"><span>Time Steps</span><span class="num">{{ qds_total }}</span></div>
                <div class="stats-metric-row"><span>Not Converged</span><span class="badge-violation">{{ qds_fail }}</span></div>
                {% if qds_rate is not none %}
                <div class="stats-metric-row"><span>Convergence</span><span class="num">{{ "%.1f"|format(qds_rate) }}%</span></div>
                {% endif %}
            </div>
            {% endif %}

        </div>
    </div>
</section>
