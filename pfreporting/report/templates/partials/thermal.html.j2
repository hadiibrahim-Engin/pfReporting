{% from 'partials/_macros.html.j2' import badge, loading_bar %}
{% if calc_options.run_thermal %}
<section class="bg-white rounded-2xl border border-slate-100 shadow mb-4" id="sec-thermal">
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 cursor-pointer select-none"
         @click="toggleSection('sec-thermal')">
        <h2 class="text-base font-semibold text-slate-800">
            Thermal Loading
            <span class="ml-2 text-xs font-normal text-slate-400">({{ loading | length }} elements)</span>
        </h2>
        <svg :class="{'rotate-180': sections['sec-thermal']}"
             class="w-5 h-5 text-slate-400 transition-transform duration-200 flex-shrink-0"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
    </div>
    <div x-show="!sections['sec-thermal']" x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" class="p-6">

        <!-- Toolbar -->
        <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
            <span class="text-xs text-slate-500">
                Warning from {{ tcfg.warning_pct }}% &nbsp;/&nbsp; Violation from {{ tcfg.violation_pct }}%
            </span>
            <label class="flex items-center gap-2 text-sm text-slate-600 cursor-pointer">
                <input type="checkbox" class="filter-toggle rounded accent-blue-600" checked>
                <span>Show only violations / warnings</span>
            </label>
        </div>

        <!-- DataTables-enabled thermal table -->
        <div class="report-table-shell">
            <div class="table-scroll">
            <table id="dt-thermal" class="report-table text-sm">
                <thead>
                    <tr>
                        <th class="text-left px-3 py-2">Element</th>
                        <th class="text-left px-3 py-2">Type</th>
                        <th class="text-left px-3 py-2">Loading</th>
                        <th class="text-right px-3 py-2">I [kA]</th>
                        <th class="text-right px-3 py-2">I_nom [kA]</th>
                        <th class="text-left px-3 py-2">Assessment</th>
                    </tr>
                </thead>
                <tbody>
                    {% for r in loading %}
                    <tr class="border-b border-slate-100 hover:bg-slate-50">
                        <td class="px-3 py-2 text-slate-800">{{ r.name }}</td>
                        <td class="px-3 py-2 text-slate-600">{{ r.type }}</td>
                        <td class="px-3 py-2">{{ loading_bar(r.loading_pct, r.status) }}</td>
                        <td class="px-3 py-2 text-right font-mono">{{ "%.3f"|format(r.i_ka) }}</td>
                        <td class="px-3 py-2 text-right font-mono">{{ "%.3f"|format(r.i_nenn_ka) }}</td>
                        <td class="px-3 py-2">{{ badge(r.status) }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>
        </div>

        {% if thermal_hm_data %}
        <div class="mt-5">
            <button class="hm-toggle-btn text-sm px-4 py-2 border border-blue-300 rounded-lg text-blue-600 font-semibold bg-blue-50 hover:bg-blue-600 hover:text-white transition-colors"
                    data-target="hm-thermal"
                    data-label-open="Show Loading Heatmap"
                    data-label-close="Hide Loading Heatmap">
                Show Loading Heatmap
            </button>
        </div>
        <div id="hm-thermal" class="hidden mt-4 border border-slate-200 rounded-xl p-4 bg-slate-50"
             data-hm="{{ thermal_hm_data | tojson | forceescape }}">
            <div class="flex flex-wrap gap-2 items-center mb-3">
                <button class="hm-select-btn text-xs px-3 py-1 border border-slate-300 rounded-lg bg-white text-slate-600 hover:border-blue-400 hover:text-blue-600" data-mode="critical">Only anomalies</button>
                <button class="hm-select-btn text-xs px-3 py-1 border border-slate-300 rounded-lg bg-white text-slate-600 hover:border-blue-400 hover:text-blue-600" data-mode="all">All</button>
                <button class="hm-select-btn text-xs px-3 py-1 border border-slate-300 rounded-lg bg-white text-slate-600 hover:border-blue-400 hover:text-blue-600" data-mode="none">None</button>
                <span class="hm-info text-xs text-slate-400 ml-auto"></span>
            </div>
            <div class="hm-elem-selector flex flex-wrap gap-1.5 mb-3 max-h-36 overflow-y-auto"></div>
            <div class="hm-render-area overflow-x-auto"></div>
        </div>
        {% endif %}

    </div>
</section>
{% endif %}
