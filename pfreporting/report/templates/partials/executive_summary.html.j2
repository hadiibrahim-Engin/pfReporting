{% set voltage_total = voltage | length %}
{% set thermal_total = loading | length %}
{% set v_viol = voltage | selectattr('status', 'eq', 'violation') | list | length %}
{% set v_warn = voltage | selectattr('status', 'eq', 'warning') | list | length %}
{% set t_viol = loading | selectattr('status', 'eq', 'violation') | list | length %}
{% set t_warn = loading | selectattr('status', 'eq', 'warning') | list | length %}
{% set v_viol_pct = (v_viol / voltage_total * 100) if voltage_total > 0 else 0 %}
{% set v_warn_pct = (v_warn / voltage_total * 100) if voltage_total > 0 else 0 %}
{% set t_viol_pct = (t_viol / thermal_total * 100) if thermal_total > 0 else 0 %}
{% set t_warn_pct = (t_warn / thermal_total * 100) if thermal_total > 0 else 0 %}
{% set v_viol_pct_c = [v_viol_pct, 100] | min %}
{% set v_warn_pct_c = [v_warn_pct, 100] | min %}
{% set t_viol_pct_c = [t_viol_pct, 100] | min %}
{% set t_warn_pct_c = [t_warn_pct, 100] | min %}

<section class="bg-white rounded-2xl border border-slate-100 shadow p-6 mb-4">
    <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-4">Analysis Summary</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">

        <div class="rounded-xl p-5 {% if v_viol > 0 %}bg-red-50 border border-red-200{% else %}bg-emerald-50 border border-emerald-200{% endif %}">
            <p class="text-xs text-slate-500 uppercase tracking-widest mb-2">Voltage Violations</p>
            <p class="text-4xl font-extrabold {% if v_viol > 0 %}text-red-600{% else %}text-emerald-600{% endif %}">{{ v_viol }}</p>
            <div class="mt-3 h-1.5 bg-slate-100 rounded-full">
                <div class="h-1.5 rounded-full {% if v_viol > 0 %}bg-red-500{% else %}bg-emerald-400{% endif %}" style="width:{{ v_viol_pct_c | round(1) }}%"></div>
            </div>
            <p class="text-xs text-slate-400 mt-1">{{ "%.1f"|format(v_viol_pct) }}% of nodes</p>
        </div>

        <div class="rounded-xl p-5 {% if v_warn > 0 %}bg-amber-50 border border-amber-200{% else %}bg-slate-50 border border-slate-200{% endif %}">
            <p class="text-xs text-slate-500 uppercase tracking-widest mb-2">Voltage Warnings</p>
            <p class="text-4xl font-extrabold {% if v_warn > 0 %}text-amber-600{% else %}text-slate-400{% endif %}">{{ v_warn }}</p>
            <div class="mt-3 h-1.5 bg-slate-100 rounded-full">
                <div class="h-1.5 rounded-full {% if v_warn > 0 %}bg-amber-400{% else %}bg-slate-300{% endif %}" style="width:{{ v_warn_pct_c | round(1) }}%"></div>
            </div>
            <p class="text-xs text-slate-400 mt-1">{{ "%.1f"|format(v_warn_pct) }}% of nodes</p>
        </div>

        <div class="rounded-xl p-5 {% if t_viol > 0 %}bg-red-50 border border-red-200{% else %}bg-emerald-50 border border-emerald-200{% endif %}">
            <p class="text-xs text-slate-500 uppercase tracking-widest mb-2">Thermal Violations</p>
            <p class="text-4xl font-extrabold {% if t_viol > 0 %}text-red-600{% else %}text-emerald-600{% endif %}">{{ t_viol }}</p>
            <div class="mt-3 h-1.5 bg-slate-100 rounded-full">
                <div class="h-1.5 rounded-full {% if t_viol > 0 %}bg-red-500{% else %}bg-emerald-400{% endif %}" style="width:{{ t_viol_pct_c | round(1) }}%"></div>
            </div>
            <p class="text-xs text-slate-400 mt-1">{{ "%.1f"|format(t_viol_pct) }}% of elements</p>
        </div>

        <div class="rounded-xl p-5 {% if t_warn > 0 %}bg-amber-50 border border-amber-200{% else %}bg-slate-50 border border-slate-200{% endif %}">
            <p class="text-xs text-slate-500 uppercase tracking-widest mb-2">Thermal Warnings</p>
            <p class="text-4xl font-extrabold {% if t_warn > 0 %}text-amber-600{% else %}text-slate-400{% endif %}">{{ t_warn }}</p>
            <div class="mt-3 h-1.5 bg-slate-100 rounded-full">
                <div class="h-1.5 rounded-full {% if t_warn > 0 %}bg-amber-400{% else %}bg-slate-300{% endif %}" style="width:{{ t_warn_pct_c | round(1) }}%"></div>
            </div>
            <p class="text-xs text-slate-400 mt-1">{{ "%.1f"|format(t_warn_pct) }}% of elements</p>
        </div>

    </div>
</section>
