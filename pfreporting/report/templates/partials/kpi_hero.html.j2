{% set voltage_total = voltage | length %}
{% set thermal_total = loading | length %}
{% set v_viol = voltage | selectattr('status', 'eq', 'violation') | list | length %}
{% set v_warn = voltage | selectattr('status', 'eq', 'warning') | list | length %}
{% set t_viol = loading | selectattr('status', 'eq', 'violation') | list | length %}
{% set t_warn = loading | selectattr('status', 'eq', 'warning') | list | length %}
{% set v_viol_pct = (v_viol / voltage_total * 100) if voltage_total > 0 else 0 %}
{% set t_viol_pct = (t_viol / thermal_total * 100) if thermal_total > 0 else 0 %}
{% set v_viol_pct_c = [v_viol_pct, 100] | min %}
{% set t_viol_pct_c = [t_viol_pct, 100] | min %}

<section id="kpi-hero" class="glass-card rounded-2xl shadow-lg p-8 mb-6">

    <!-- Header -->
    <div class="mb-6">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-1">Assessment Result</p>
        <h2 class="text-2xl font-bold text-slate-900">{{ info.project }}</h2>
        <p class="text-sm text-slate-400 mt-0.5">{{ info.study_case }} &mdash; {{ info.date }} {{ info.time }}</p>
    </div>

    <!-- PRIMARY KPI CARDS -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6">

        <!-- Total Violations — hero number (voltage + thermal only) -->
        <div class="glass-kpi rounded-2xl p-6 flex flex-col gap-2 border-2
                    {% if (v_viol + t_viol) > 0 %}bg-red-50/60 border-red-300{% else %}bg-emerald-50/60 border-emerald-300{% endif %}">
            <p class="text-xs font-semibold uppercase tracking-[0.15em] text-slate-500">Total Violations</p>
            <p class="text-7xl font-black leading-none {% if (v_viol + t_viol) > 0 %}text-red-600{% else %}text-emerald-600{% endif %}">
                {{ v_viol + t_viol }}
            </p>
            <p class="text-xs text-slate-400">voltage &amp; thermal</p>
        </div>

        <!-- Voltage Violations — clickable → tab-tables #sec-voltage -->
        {% if multipage %}<a href="./tables.html#sec-voltage" class="glass-kpi rounded-2xl p-6 flex flex-col gap-2 group">
        {% else %}<div class="glass-kpi rounded-2xl p-6 flex flex-col gap-2 group cursor-pointer"
             @click="setTab('tab-tables'); $nextTick(() => { var el = document.getElementById('sec-voltage'); if(el) el.scrollIntoView({behavior:'smooth'}); })">{% endif %}
            <p class="text-xs font-semibold uppercase tracking-[0.15em] text-slate-500">Voltage Violations</p>
            <p class="text-5xl font-extrabold leading-none {% if v_viol > 0 %}text-red-600{% else %}text-slate-300{% endif %}">
                {{ v_viol }}
            </p>
            <p class="text-xs text-slate-400">{{ v_warn }} warning{{ 's' if v_warn != 1 else '' }}</p>
            <div class="mt-auto">
                <div class="h-1.5 rounded-full bg-slate-100">
                    <div class="h-1.5 rounded-full {% if v_viol > 0 %}bg-red-500{% else %}bg-emerald-400{% endif %} transition-all duration-500"
                         style="width:{{ v_viol_pct_c | round(1) }}%"></div>
                </div>
                <p class="text-xs text-slate-400 mt-1">{{ "%.1f"|format(v_viol_pct) }}% of {{ voltage_total }} nodes</p>
            </div>
            <p class="text-xs text-blue-500 opacity-0 group-hover:opacity-100 transition-opacity mt-1">→ View table</p>
        {% if multipage %}</a>{% else %}</div>{% endif %}

        <!-- Thermal Violations — clickable → tab-tables #sec-thermal -->
        {% if multipage %}<a href="./tables.html#sec-thermal" class="glass-kpi rounded-2xl p-6 flex flex-col gap-2 group">
        {% else %}<div class="glass-kpi rounded-2xl p-6 flex flex-col gap-2 group cursor-pointer"
             @click="setTab('tab-tables'); $nextTick(() => { var el = document.getElementById('sec-thermal'); if(el) el.scrollIntoView({behavior:'smooth'}); })">{% endif %}
            <p class="text-xs font-semibold uppercase tracking-[0.15em] text-slate-500">Thermal Violations</p>
            <p class="text-5xl font-extrabold leading-none {% if t_viol > 0 %}text-red-600{% else %}text-slate-300{% endif %}">
                {{ t_viol }}
            </p>
            <p class="text-xs text-slate-400">{{ t_warn }} warning{{ 's' if t_warn != 1 else '' }}</p>
            <div class="mt-auto">
                <div class="h-1.5 rounded-full bg-slate-100">
                    <div class="h-1.5 rounded-full {% if t_viol > 0 %}bg-red-500{% else %}bg-emerald-400{% endif %} transition-all duration-500"
                         style="width:{{ t_viol_pct_c | round(1) }}%"></div>
                </div>
                <p class="text-xs text-slate-400 mt-1">{{ "%.1f"|format(t_viol_pct) }}% of {{ thermal_total }} elements</p>
            </div>
            <p class="text-xs text-blue-500 opacity-0 group-hover:opacity-100 transition-opacity mt-1">→ View table</p>
        {% if multipage %}</a>{% else %}</div>{% endif %}

    </div>

    <!-- SECONDARY METRICS ROW -->
    <div class="grid grid-cols-3 sm:grid-cols-6 gap-3 mb-6">
        <div class="rounded-xl bg-white/50 border border-slate-200/70 p-4 text-center card-hover">
            <div class="text-3xl font-bold text-slate-800">{{ overall.total_nodes }}</div>
            <div class="text-xs text-slate-500 uppercase tracking-wide mt-1">Nodes</div>
        </div>
        <div class="rounded-xl bg-white/50 border border-slate-200/70 p-4 text-center card-hover">
            <div class="text-3xl font-bold text-slate-800">{{ overall.total_elements }}</div>
            <div class="text-xs text-slate-500 uppercase tracking-wide mt-1">Elements</div>
        </div>
        {% if calc_options.run_loadflow and lf %}
        <div class="rounded-xl bg-white/50 border border-slate-200/70 p-4 text-center card-hover">
            <div class="text-2xl font-bold text-slate-800">{{ "%.1f"|format(lf.total_load_mw) }}</div>
            <div class="text-xs text-slate-500 uppercase tracking-wide mt-1">Load [MW]</div>
        </div>
        <div class="rounded-xl bg-white/50 border border-slate-200/70 p-4 text-center card-hover">
            <div class="text-2xl font-bold text-slate-800">{{ "%.1f"|format(lf.total_gen_mw) }}</div>
            <div class="text-xs text-slate-500 uppercase tracking-wide mt-1">Gen [MW]</div>
        </div>
        <div class="rounded-xl bg-white/50 border border-slate-200/70 p-4 text-center card-hover">
            <div class="text-2xl font-bold text-slate-800">{{ "%.2f"|format(lf.losses_mw) }}</div>
            <div class="text-xs text-slate-500 uppercase tracking-wide mt-1">Losses [MW]</div>
        </div>
        {% endif %}
    </div>

    <!-- CRITICAL ELEMENTS — click to jump to exact table row -->
    {% if top_voltage_violations or top_loading_violations %}
    <div class="border border-red-100 rounded-xl p-5 bg-red-50/50 backdrop-blur-sm">
        <h4 class="text-xs font-bold text-red-700 uppercase tracking-widest mb-1">Critical Elements</h4>
        <p class="text-xs text-red-400 mb-4">Click any row to jump directly to the table</p>
        <div class="grid sm:grid-cols-2 gap-5">
            {% if top_voltage_violations %}
            <div>
                <p class="text-xs font-semibold text-slate-600 mb-2">Voltage Violations</p>
                {% for r in top_voltage_violations %}
                {% if multipage %}<a href="./tables.html#sec-voltage" class="crit-link flex justify-between items-center py-1.5 border-b border-red-100 text-xs gap-3 rounded px-1">
                {% else %}<div class="crit-link flex justify-between items-center py-1.5 border-b border-red-100 text-xs gap-3 rounded px-1"
                     @click="setTab('tab-tables'); $nextTick(() => navigateToRow('{{ r.node | replace("'", "\\'") }}', 'voltage'))">{% endif %}
                    <span class="truncate text-slate-700 font-medium">{{ r.node }}</span>
                    <span class="flex items-center gap-1.5 flex-shrink-0">
                        <span class="badge-violation">{{ "%.4f"|format(r.u_pu) }} p.u.</span>
                        <span class="nav-arrow">↗</span>
                    </span>
                {% if multipage %}</a>{% else %}</div>{% endif %}
                {% endfor %}
            </div>
            {% endif %}
            {% if top_loading_violations %}
            <div>
                <p class="text-xs font-semibold text-slate-600 mb-2">Thermal Violations</p>
                {% for r in top_loading_violations %}
                {% if multipage %}<a href="./tables.html#sec-thermal" class="crit-link flex justify-between items-center py-1.5 border-b border-red-100 text-xs gap-3 rounded px-1">
                {% else %}<div class="crit-link flex justify-between items-center py-1.5 border-b border-red-100 text-xs gap-3 rounded px-1"
                     @click="setTab('tab-tables'); $nextTick(() => navigateToRow('{{ r.name | replace("'", "\\'") }}', 'thermal'))">{% endif %}
                    <span class="truncate text-slate-700 font-medium">{{ r.name }}</span>
                    <span class="flex items-center gap-1.5 flex-shrink-0">
                        <span class="badge-violation">{{ "%.1f"|format(r.loading_pct) }}%</span>
                        <span class="nav-arrow">↗</span>
                    </span>
                {% if multipage %}</a>{% else %}</div>{% endif %}
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

</section>
