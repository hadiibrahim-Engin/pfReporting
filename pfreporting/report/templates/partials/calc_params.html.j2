<section class="bg-white rounded-2xl border border-slate-100 shadow mb-4" id="sec-calc-params">
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 cursor-pointer select-none"
         @click="toggleSection('sec-calc-params')">
        <h2 class="text-base font-semibold text-slate-800">Calculation Parameters</h2>
        <svg :class="{'rotate-180': sections['sec-calc-params']}"
             class="w-5 h-5 text-slate-400 transition-transform duration-200 flex-shrink-0"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
    </div>
    <div x-show="!sections['sec-calc-params']" x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" class="p-6">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">

            <div class="bg-slate-50 border border-slate-200 rounded-xl p-4">
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Load Flow Settings</p>
                <dl class="divide-y divide-slate-100">
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Method</dt>
                        <dd class="text-slate-800 font-medium text-right">Newton-Raphson, AC, pos. seq.</dd>
                    </div>
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Active Power Control</dt>
                        <dd class="text-slate-800 font-medium">As dispatched</dd>
                    </div>
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Temperature</dt>
                        <dd class="text-slate-800 font-medium">20 °C (default)</dd>
                    </div>
                </dl>
            </div>

            {% if calc_options.run_voltage %}
            <div class="bg-slate-50 border border-slate-200 rounded-xl p-4">
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Voltage Limits</p>
                <dl class="divide-y divide-slate-100">
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Lower Violation</dt>
                        <dd class="font-semibold text-red-600">&le; {{ vcfg.lower_violation }} p.u.</dd>
                    </div>
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Lower Warning</dt>
                        <dd class="font-semibold text-amber-600">&le; {{ vcfg.lower_warning }} p.u.</dd>
                    </div>
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Upper Warning</dt>
                        <dd class="font-semibold text-amber-600">&ge; {{ vcfg.upper_warning }} p.u.</dd>
                    </div>
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Upper Violation</dt>
                        <dd class="font-semibold text-red-600">&ge; {{ vcfg.upper_violation }} p.u.</dd>
                    </div>
                </dl>
            </div>
            {% endif %}

            {% if calc_options.run_thermal %}
            <div class="bg-slate-50 border border-slate-200 rounded-xl p-4">
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Thermal Loading Limits</p>
                <dl class="divide-y divide-slate-100">
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Warning Threshold</dt>
                        <dd class="font-semibold text-amber-600">&ge; {{ tcfg.warning_pct }}%</dd>
                    </div>
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Violation Threshold</dt>
                        <dd class="font-semibold text-red-600">&ge; {{ tcfg.violation_pct }}%</dd>
                    </div>
                </dl>
            </div>
            {% endif %}

            {% if calc_options.run_n1 %}
            <div class="bg-slate-50 border border-slate-200 rounded-xl p-4">
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">N-1 Criteria</p>
                <dl class="divide-y divide-slate-100">
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Max. Loading</dt>
                        <dd class="font-semibold text-red-600">&gt; {{ n1cfg.max_loading_pct }}%</dd>
                    </div>
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Min. Voltage</dt>
                        <dd class="font-semibold text-red-600">&lt; {{ n1cfg.min_voltage_pu }} p.u.</dd>
                    </div>
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Max. Voltage</dt>
                        <dd class="font-semibold text-red-600">&gt; {{ n1cfg.max_voltage_pu }} p.u.</dd>
                    </div>
                </dl>
            </div>
            {% endif %}

            {% if calc_options.run_qds and qds_info %}
            <div class="bg-slate-50 border border-slate-200 rounded-xl p-4">
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Quasi-Dynamic Simulation</p>
                <dl class="divide-y divide-slate-100">
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Period</dt>
                        <dd class="font-medium text-slate-800">{{ "%.2f"|format(qds_info.t_start_h) }} – {{ "%.2f"|format(qds_info.t_end_h) }} h</dd>
                    </div>
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Time Step</dt>
                        <dd class="font-medium text-slate-800">{{ "%.4g"|format(qds_info.dt_h) }} h</dd>
                    </div>
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Steps</dt>
                        <dd class="font-medium text-slate-800">{{ qds_info.n_steps }}</dd>
                    </div>
                    {% if qds_info.result_file %}
                    <div class="flex justify-between py-1.5 text-xs">
                        <dt class="text-slate-500">Result File</dt>
                        <dd class="font-mono text-slate-700 text-right break-all max-w-[160px]">{{ qds_info.result_file }}</dd>
                    </div>
                    {% endif %}
                </dl>
            </div>
            {% endif %}

        </div>
    </div>
</section>
