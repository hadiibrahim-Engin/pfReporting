{% if calc_options.run_qds %}
<section id="sec-qds-info">
    <div class="section-header">
        <h2>Quasi-Dynamic Simulation – Settings</h2>
        <button class="section-toggle" data-target="sec-qds-info" title="Collapse / Expand">▾</button>
    </div>
    <div class="section-body">
        <div class="qds-info-grid">
            <div class="qds-info-item">
                <div class="qds-info-label">Project</div>
                <div class="qds-info-value">{{ info.project }}</div>
            </div>
            <div class="qds-info-item">
                <div class="qds-info-label">Study Case</div>
                <div class="qds-info-value">{{ info.study_case }}</div>
            </div>
            {% if qds_info %}
            {% if qds_info.scenario %}
            <div class="qds-info-item">
                <div class="qds-info-label">Scenario</div>
                <div class="qds-info-value">{{ qds_info.scenario }}</div>
            </div>
            {% endif %}
            {% if qds_info.study_time_start %}
            <div class="qds-info-item">
                <div class="qds-info-label">Start Time (Calendar)</div>
                <div class="qds-info-value">{{ qds_info.study_time_start }}</div>
            </div>
            {% endif %}
            <div class="qds-info-item">
                <div class="qds-info-label">Simulation Period</div>
                <div class="qds-info-value">
                    {{ "%.2f"|format(qds_info.t_start_h) }} h – {{ "%.2f"|format(qds_info.t_end_h) }} h
                </div>
            </div>
            <div class="qds-info-item">
                <div class="qds-info-label">Time Step</div>
                <div class="qds-info-value">{{ "%.4g"|format(qds_info.dt_h) }} h</div>
            </div>
            <div class="qds-info-item">
                <div class="qds-info-label">Number of Steps</div>
                <div class="qds-info-value">{{ qds_info.n_steps }}</div>
            </div>
            {% if qds_info.result_file %}
            <div class="qds-info-item">
                <div class="qds-info-label">Result File</div>
                <div class="qds-info-value" style="font-size:12px;">{{ qds_info.result_file }}</div>
            </div>
            {% endif %}
            {% endif %}
            <div class="qds-info-item">
                <div class="qds-info-label">Created</div>
                <div class="qds-info-value">{{ info.datetime_full }}</div>
            </div>
            <div class="qds-info-item">
                <div class="qds-info-label">Author</div>
                <div class="qds-info-value">{{ info.author }}</div>
            </div>
        </div>
    </div>
</section>
{% endif %}
