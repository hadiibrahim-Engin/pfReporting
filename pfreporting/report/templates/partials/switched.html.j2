<section class="bg-white rounded-2xl border border-slate-100 shadow mb-4" id="sec-switched">
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 cursor-pointer select-none"
         @click="toggleSection('sec-switched')">
        <h2 class="text-base font-semibold text-slate-800">
            De-Energized Equipment
            {% if switched %}<span class="ml-2 text-xs font-normal text-slate-400">({{ switched | length }})</span>{% endif %}
        </h2>
        <svg :class="{'rotate-180': sections['sec-switched']}"
             class="w-5 h-5 text-slate-400 transition-transform duration-200 flex-shrink-0"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
    </div>
    <div x-show="!sections['sec-switched']" x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" class="p-6">
        {% if switched %}
        <div class="report-table-shell">
            <div class="table-scroll">
            <table class="report-table text-sm">
                <thead>
                    <tr class="border-b border-slate-200">
                        <th class="text-left px-3 py-2 font-semibold text-slate-600 bg-slate-50" data-sort="text">Name</th>
                        <th class="text-left px-3 py-2 font-semibold text-slate-600 bg-slate-50">Type</th>
                        <th class="text-left px-3 py-2 font-semibold text-slate-600 bg-slate-50">Status Before</th>
                        <th class="text-left px-3 py-2 font-semibold text-slate-600 bg-slate-50">Status Assessment</th>
                    </tr>
                </thead>
                <tbody>
                    {% for el in switched %}
                    <tr class="border-b border-slate-100 hover:bg-slate-50">
                        <td class="px-3 py-2 font-semibold text-slate-800">{{ el.name }}</td>
                        <td class="px-3 py-2 text-slate-600">{{ el.type }}</td>
                        <td class="px-3 py-2 text-slate-600">{{ el.status_before }}</td>
                        <td class="px-3 py-2"><span class="badge-violation">{{ el.status_assessment }}</span></td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>
        </div>
        {% else %}
        <p class="text-slate-400 text-sm">No equipment de-energized.</p>
        {% endif %}
    </div>
</section>
