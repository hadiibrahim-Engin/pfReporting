{% from 'partials/_macros.html.j2' import badge %}
{% if calc_options.run_voltage %}
<section id="sec-voltage">
    <div class="section-header">
        <h2>Voltage Band Check</h2>
        <div class="section-toolbar-right">
            <input type="text" class="section-search" data-section="sec-voltage"
                   placeholder="Search …" autocomplete="off">
            <button class="section-toggle" data-target="sec-voltage" title="Collapse / Expand">▾</button>
        </div>
    </div>
    <div class="section-body">
        <div class="section-toolbar">
            <span class="limit-info">
                Limits: {{ vcfg.lower_violation }}-{{ vcfg.lower_warning }} /
                {{ vcfg.upper_warning }}-{{ vcfg.upper_violation }} p.u.
            </span>
            <div class="toolbar-right">
                <button class="filter-btn">Only anomalies</button>
            </div>
        </div>
        <table>
            <thead>
                <tr>
                    <th data-sort="text">Node</th>
                    <th data-sort="num">U_nom [kV]</th>
                    <th data-sort="num">U [kV]</th>
                    <th data-sort="num">U [p.u.]</th>
                    <th data-sort="num">Dev. [%]</th>
                    <th>Assessment</th>
                </tr>
            </thead>
            <tbody>
                {% for r in voltage %}
                <tr>
                    <td>{{ r.node }}</td>
                    <td class="num">{{ "%.1f"|format(r.u_nenn_kv) }}</td>
                    <td class="num">{{ "%.2f"|format(r.u_kv) }}</td>
                    <td class="num">{{ "%.4f"|format(r.u_pu) }}</td>
                    <td class="num">{{ "%+.2f"|format(r.deviation_pct) }}</td>
                    <td>{{ badge(r.status) }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        {% if voltage_by_level %}
        <div style="margin-top:24px;">
            <h3 style="font-size:14px;font-weight:600;margin-bottom:10px;color:var(--gray-800);">
                Summary by Voltage Level
            </h3>
            <table class="compact-table">
                <thead>
                    <tr>
                        <th>U_nom [kV]</th>
                        <th data-sort="num">Nodes</th>
                        <th data-sort="num">Min [p.u.]</th>
                        <th data-sort="num">Max [p.u.]</th>
                        <th data-sort="num">Violations</th>
                        <th data-sort="num">Warnings</th>
                    </tr>
                </thead>
                <tbody>
                {% for kv, nodes in voltage_by_level.items() %}
                <tr>
                    <td>{{ "%.0f"|format(kv) }}</td>
                    <td class="num">{{ nodes | length }}</td>
                    <td class="num">{{ "%.4f"|format(nodes | map(attribute='u_pu') | min) }}</td>
                    <td class="num">{{ "%.4f"|format(nodes | map(attribute='u_pu') | max) }}</td>
                    <td class="num">
                        {% set n_viol = nodes | selectattr('status', 'eq', 'violation') | list | length %}
                        {% if n_viol > 0 %}
                        <span class="badge-violation">{{ n_viol }}</span>
                        {% else %}0{% endif %}
                    </td>
                    <td class="num">
                        {% set n_warn = nodes | selectattr('status', 'eq', 'warning') | list | length %}
                        {% if n_warn > 0 %}
                        <span class="badge-warning">{{ n_warn }}</span>
                        {% else %}0{% endif %}
                    </td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        {% if voltage_hm_data %}
        <div class="hm-toggle-row">
            <button class="hm-toggle-btn"
                    data-target="hm-voltage"
                    data-label-open="Show Voltage Heatmap"
                    data-label-close="Hide Voltage Heatmap">
                Show Voltage Heatmap
            </button>
        </div>
        <div id="hm-voltage" class="hm-panel" style="display:none;"
             data-hm="{{ voltage_hm_data | tojson | e }}">
            <div class="hm-controls-bar">
                <button class="hm-select-btn" data-mode="critical">Only anomalies</button>
                <button class="hm-select-btn" data-mode="all">All</button>
                <button class="hm-select-btn" data-mode="none">None</button>
                <span class="hm-info"></span>
            </div>
            <div class="hm-elem-selector"></div>
            <div class="hm-render-area"></div>
        </div>
        {% endif %}
    </div>
</section>
{% endif %}
