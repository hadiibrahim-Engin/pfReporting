{% from 'partials/_macros.html.j2' import badge %}
{% if calc_options.run_voltage %}
<section class="bg-white rounded-2xl border border-slate-100 shadow mb-4" id="sec-voltage">
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 cursor-pointer select-none"
         @click="toggleSection('sec-voltage')">
        <h2 class="text-base font-semibold text-slate-800">
            Voltage Band Check
            <span class="ml-2 text-xs font-normal text-slate-400">({{ voltage | length }} nodes)</span>
        </h2>
        <svg :class="{'rotate-180': sections['sec-voltage']}"
             class="w-5 h-5 text-slate-400 transition-transform duration-200 flex-shrink-0"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
    </div>
    <div x-show="!sections['sec-voltage']" x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" class="p-6">

        <!-- Toolbar -->
        <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
            <span class="text-xs text-slate-500">
                Limits: {{ vcfg.lower_violation }}&ndash;{{ vcfg.lower_warning }} /
                {{ vcfg.upper_warning }}&ndash;{{ vcfg.upper_violation }} p.u.
            </span>
            <label class="flex items-center gap-2 text-sm text-slate-600 cursor-pointer">
                <input type="checkbox" class="filter-toggle rounded accent-blue-600" checked>
                <span>Show only violations / warnings</span>
            </label>
        </div>

        <!-- DataTables-enabled voltage table -->
        <div class="overflow-x-auto">
            <table id="dt-voltage" class="w-full text-sm">
                <thead>
                    <tr>
                        <th class="text-left px-3 py-2">Node</th>
                        <th class="text-right px-3 py-2">U_nom [kV]</th>
                        <th class="text-right px-3 py-2">U [kV]</th>
                        <th class="text-right px-3 py-2">U [p.u.]</th>
                        <th class="text-right px-3 py-2">Dev. [%]</th>
                        <th class="text-left px-3 py-2">Assessment</th>
                    </tr>
                </thead>
                <tbody>
                    {% for r in voltage %}
                    <tr class="border-b border-slate-100 hover:bg-slate-50">
                        <td class="px-3 py-2 text-slate-800">{{ r.node }}</td>
                        <td class="px-3 py-2 text-right font-mono">{{ "%.1f"|format(r.u_nenn_kv) }}</td>
                        <td class="px-3 py-2 text-right font-mono">{{ "%.2f"|format(r.u_kv) }}</td>
                        <td class="px-3 py-2 text-right font-mono font-semibold">{{ "%.4f"|format(r.u_pu) }}</td>
                        <td class="px-3 py-2 text-right font-mono">{{ "%+.2f"|format(r.deviation_pct) }}</td>
                        <td class="px-3 py-2">{{ badge(r.status) }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% if voltage_by_level %}
        <div class="mt-6">
            <h3 class="text-sm font-semibold text-slate-700 mb-3">Summary by Voltage Level</h3>
            <div class="overflow-x-auto">
                <table class="w-auto text-sm">
                    <thead>
                        <tr class="border-b border-slate-200">
                            <th class="text-left px-3 py-2 font-semibold text-slate-600 bg-slate-50">U_nom [kV]</th>
                            <th class="text-right px-3 py-2 font-semibold text-slate-600 bg-slate-50">Nodes</th>
                            <th class="text-right px-3 py-2 font-semibold text-slate-600 bg-slate-50">Min [p.u.]</th>
                            <th class="text-right px-3 py-2 font-semibold text-slate-600 bg-slate-50">Max [p.u.]</th>
                            <th class="text-right px-3 py-2 font-semibold text-slate-600 bg-slate-50">Violations</th>
                            <th class="text-right px-3 py-2 font-semibold text-slate-600 bg-slate-50">Warnings</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for kv, nodes in voltage_by_level.items() %}
                        <tr class="border-b border-slate-100 hover:bg-slate-50">
                            <td class="px-3 py-2 font-semibold text-slate-800">{{ "%.0f"|format(kv) }}</td>
                            <td class="px-3 py-2 text-right font-mono">{{ nodes | length }}</td>
                            <td class="px-3 py-2 text-right font-mono">{{ "%.4f"|format(nodes | map(attribute='u_pu') | min) }}</td>
                            <td class="px-3 py-2 text-right font-mono">{{ "%.4f"|format(nodes | map(attribute='u_pu') | max) }}</td>
                            <td class="px-3 py-2 text-right">
                                {% set n_viol = nodes | selectattr('status', 'eq', 'violation') | list | length %}
                                {% if n_viol > 0 %}<span class="badge-violation">{{ n_viol }}</span>{% else %}0{% endif %}
                            </td>
                            <td class="px-3 py-2 text-right">
                                {% set n_warn = nodes | selectattr('status', 'eq', 'warning') | list | length %}
                                {% if n_warn > 0 %}<span class="badge-warning">{{ n_warn }}</span>{% else %}0{% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}

        {% if voltage_hm_data %}
        <div class="mt-5">
            <button class="hm-toggle-btn text-sm px-4 py-2 border border-blue-300 rounded-lg text-blue-600 font-semibold bg-blue-50 hover:bg-blue-600 hover:text-white transition-colors"
                    data-target="hm-voltage"
                    data-label-open="Show Voltage Heatmap"
                    data-label-close="Hide Voltage Heatmap">
                Show Voltage Heatmap
            </button>
        </div>
        <div id="hm-voltage" class="hidden mt-4 border border-slate-200 rounded-xl p-4 bg-slate-50"
             data-hm="{{ voltage_hm_data | tojson | e }}">
            <div class="flex flex-wrap gap-2 items-center mb-3">
                <button class="hm-select-btn text-xs px-3 py-1 border border-slate-300 rounded-lg bg-white text-slate-600 hover:border-blue-400 hover:text-blue-600" data-mode="critical">Only anomalies</button>
                <button class="hm-select-btn text-xs px-3 py-1 border border-slate-300 rounded-lg bg-white text-slate-600 hover:border-blue-400 hover:text-blue-600" data-mode="all">All</button>
                <button class="hm-select-btn text-xs px-3 py-1 border border-slate-300 rounded-lg bg-white text-slate-600 hover:border-blue-400 hover:text-blue-600" data-mode="none">None</button>
                <span class="hm-info text-xs text-slate-400 ml-auto"></span>
            </div>
            <div class="hm-elem-selector flex flex-wrap gap-1.5 mb-3 max-h-36 overflow-y-auto"></div>
            <div class="hm-render-area overflow-x-auto"></div>
        </div>
        {% endif %}

    </div>
</section>
{% endif %}
