{% if calc_options.run_qds %}
<section class="bg-white rounded-2xl border border-slate-100 shadow mb-4" id="sec-timeseries">
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 cursor-pointer select-none"
         @click="toggleSection('sec-timeseries')">
        <h2 class="text-base font-semibold text-slate-800">Quasi-Dynamic Time Series</h2>
        <svg :class="{'rotate-180': sections['sec-timeseries']}"
             class="w-5 h-5 text-slate-400 transition-transform duration-200 flex-shrink-0"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
    </div>
    <div x-show="!sections['sec-timeseries']" x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" class="p-6">
        <p class="text-xs text-slate-400 mb-5">
            Elements without a threshold always appear. Elements with thresholds are shown only when they exceed the warning level at least once.
            Zoom: mouse wheel &middot; Pan: drag.
        </p>

        {% for viz in viz_requests %}
        {% set cid = viz.chart_id %}
        {% if cid in ts_data.sections and ts_data.sections[cid] %}

        <div class="mb-8">
            <h3 class="text-sm font-semibold text-slate-700 mb-3">
                {{ viz.label }}
                <span class="text-xs font-normal text-slate-400 ml-2">[{{ viz.unit }}] &mdash; {{ ts_data.sections[cid] | length }} elements</span>
            </h3>
            <div class="bg-slate-50 border border-slate-200 rounded-xl p-4">
                <div id="chart-{{ cid }}" class="chart-wrapper"></div>
                <p class="text-xs text-slate-400 mt-2 text-right">Scroll: Zoom &middot; Drag: Pan &middot; Double-click: Reset</p>
            </div>
        </div>

        {% if viz.heatmap and cid in heatmap_data %}
        <div class="mb-8">
            <h4 class="text-sm font-semibold text-slate-600 mb-2">Heatmap &mdash; {{ viz.label }}</h4>
            <div class="overflow-x-auto border border-slate-200 rounded-xl p-3 bg-slate-50">
                <div data-heatmap="{{ heatmap_data[cid] | tojson | e }}"></div>
            </div>
        </div>
        {% endif %}

        {% endif %}
        {% endfor %}
    </div>
</section>
{% endif %}
