<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Freischaltbewertung &mdash; {{ info.project }} &mdash; {{ info.date }}</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.tailwindcss.min.css">
    <style>{{ css }}</style>
</head>
<body class="text-slate-800 font-sans antialiased"
      x-data="reportApp()"
      x-cloak>

{# ==================== STICKY NAVIGATION ==================== #}
<nav class="sticky top-0 z-50 glass-nav shadow-sm">
    <div class="max-w-screen-xl mx-auto px-4 flex items-center gap-1 h-14 overflow-x-auto">

        <button @click="setTab('tab-overview')"
                :class="activeTab === 'tab-overview'
                    ? 'bg-blue-600 text-white shadow-md ring-2 ring-blue-300/50'
                    : 'text-slate-600 hover:bg-blue-50 hover:text-blue-700'"
                class="flex-shrink-0 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-150 whitespace-nowrap">
            Overview
        </button>

        <button @click="setTab('tab-statistics')"
                :class="activeTab === 'tab-statistics'
                    ? 'bg-blue-600 text-white shadow-md ring-2 ring-blue-300/50'
                    : 'text-slate-600 hover:bg-blue-50 hover:text-blue-700'"
                class="flex-shrink-0 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-150 whitespace-nowrap">
            Statistics
        </button>

        {% if calc_options.run_qds %}
        <button @click="setTab('tab-qds')"
                :class="activeTab === 'tab-qds'
                    ? 'bg-blue-600 text-white shadow-md ring-2 ring-blue-300/50'
                    : 'text-slate-600 hover:bg-blue-50 hover:text-blue-700'"
                class="flex-shrink-0 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-150 whitespace-nowrap">
            Quasi-Dynamic
        </button>
        {% endif %}

        <button @click="setTab('tab-tables')"
                :class="activeTab === 'tab-tables'
                    ? 'bg-blue-600 text-white shadow-md ring-2 ring-blue-300/50'
                    : 'text-slate-600 hover:bg-blue-50 hover:text-blue-700'"
                class="flex-shrink-0 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-150 whitespace-nowrap">
            Tables
            {% if overall.total_violations > 0 %}
            <span class="ml-1.5 bg-red-500 text-white text-xs rounded-full px-1.5 py-0.5 animate-pulse">{{ overall.total_violations }}</span>
            {% endif %}
        </button>

        <button @click="setTab('tab-details')"
                :class="activeTab === 'tab-details'
                    ? 'bg-blue-600 text-white shadow-md ring-2 ring-blue-300/50'
                    : 'text-slate-600 hover:bg-blue-50 hover:text-blue-700'"
                class="flex-shrink-0 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-150 whitespace-nowrap">
            Details
        </button>

        <!-- Jump links -->
        <div class="ml-auto flex items-center gap-3 text-xs text-slate-400 flex-shrink-0 pl-4 border-l border-slate-200">
            {% if calc_options.run_voltage %}<a @click.prevent="setTab('tab-tables')" href="#sec-voltage" class="hover:text-blue-600 transition-colors whitespace-nowrap cursor-pointer">Voltage</a>{% endif %}
            {% if calc_options.run_thermal %}<a @click.prevent="setTab('tab-tables')" href="#sec-thermal" class="hover:text-blue-600 transition-colors whitespace-nowrap cursor-pointer">Thermal</a>{% endif %}
            {% if calc_options.run_n1 %}<a @click.prevent="setTab('tab-tables')" href="#sec-n1" class="hover:text-blue-600 transition-colors whitespace-nowrap cursor-pointer">N-1</a>{% endif %}
        </div>
    </div>
</nav>

{# ==================== MAIN CONTENT ==================== #}
<main class="max-w-screen-xl mx-auto px-4 py-6">

    {# ---- TAB: OVERVIEW (header + verdict + KPIs + summary + board) ---- #}
    <div x-show="activeTab === 'tab-overview'"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 translate-y-1"
         x-transition:enter-end="opacity-100 translate-y-0">
        {% include 'partials/header.html.j2' %}
        {% include 'partials/ampel.html.j2' %}
        {% include 'partials/kpi_hero.html.j2' %}
        {% include 'partials/summary.html.j2' %}
        {% include 'partials/overview_board.html.j2' %}
        {% include 'partials/executive_summary.html.j2' %}
    </div>

    {# ---- TAB: STATISTICS ---- #}
    <div x-show="activeTab === 'tab-statistics'"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 translate-y-1"
         x-transition:enter-end="opacity-100 translate-y-0">
        {% include 'partials/statistics.html.j2' %}
    </div>

    {# ---- TAB: QUASI-DYNAMIC ---- #}
    {% if calc_options.run_qds %}
    <div x-show="activeTab === 'tab-qds'"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 translate-y-1"
         x-transition:enter-end="opacity-100 translate-y-0">
        {% include 'partials/qds_info.html.j2' %}
        {% if ts_data and not ts_data.is_empty() %}
        {% include 'partials/timeseries.html.j2' %}
        {% else %}
        <div class="glass-card rounded-2xl shadow p-8 text-center text-slate-400">
            <p class="text-lg">No time series data available.</p>
            <p class="text-sm mt-2">Run the quasi-dynamic simulation to generate chart data.</p>
        </div>
        {% endif %}
    </div>
    {% endif %}

    {# ---- TAB: TABLES ---- #}
    <div x-show="activeTab === 'tab-tables'"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 translate-y-1"
         x-transition:enter-end="opacity-100 translate-y-0">

        <!-- Global search bar -->
        <div class="flex items-center gap-3 glass-card rounded-xl px-4 py-3 mb-5">
            <svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text" id="global-search"
                   placeholder="Search across all tables (node name, element …)"
                   autocomplete="off"
                   class="flex-1 text-sm outline-none bg-transparent placeholder-slate-400">
            <span id="search-count" class="text-xs text-slate-400 flex-shrink-0"></span>
        </div>

        {% include 'partials/switched.html.j2' %}
        {% include 'partials/loadflow.html.j2' %}
        {% if calc_options.run_voltage %}{% include 'partials/voltage.html.j2' %}{% endif %}
        {% if calc_options.run_thermal %}{% include 'partials/thermal.html.j2' %}{% endif %}
        {% if calc_options.run_n1 %}{% include 'partials/n1.html.j2' %}{% endif %}
    </div>

    {# ---- TAB: DETAILS ---- #}
    <div x-show="activeTab === 'tab-details'"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 translate-y-1"
         x-transition:enter-end="opacity-100 translate-y-0">
        {% include 'partials/calc_params.html.j2' %}
        {% include 'partials/footer.html.j2' %}
    </div>

</main>

{# ==================== VENDOR JS (inlined, offline-capable) ==================== #}
<script>{{ vendor_js.hammer }}</script>
<script>{{ vendor_js.chart }}</script>
<script>{{ vendor_js.zoom }}</script>

{# DataTables (CDN, requires internet) #}
<script src="https://code.jquery.com/jquery-3.7.1.min.js"
        integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.tailwindcss.min.js"></script>

{# Chart data payload #}
<script>window.__chartData = {{ chart_data_json }};</script>

{# Application JS (heatmap, search, sort, filter — vanilla JS) #}
<script>{{ scripts }}</script>

{# Alpine root component + DataTables init #}
<script>
function reportApp() {
    return {
        activeTab: 'tab-overview',
        sections: {
            'sec-voltage':     false,
            'sec-thermal':     false,
            'sec-n1':          false,
            'sec-switched':    false,
            'sec-loadflow':    false,
            'sec-statistics':  false,
            'sec-qds-info':    false,
            'sec-timeseries':  false,
            'sec-calc-params': false,
        },
        setTab: function(id) {
            this.activeTab = id;
            var self = this;
            this.$nextTick(function() {
                if (id === 'tab-qds' && typeof initCharts === 'function') {
                    initCharts();
                }
            });
        },
        toggleSection: function(id) {
            this.sections[id] = !this.sections[id];
        }
    };
}

$(document).ready(function() {

    /* ---------------------------------------------------------------
       DataTables external search — violation/warning filter
       Uses DT's own search pipeline so pagination works correctly.
    --------------------------------------------------------------- */
    window.__dtFilterActive = {};

    $.fn.dataTable.ext.search.push(function(settings, rowData, dataIndex) {
        var tableId = settings.nTable && settings.nTable.id;
        if (!window.__dtFilterActive[tableId]) return true;
        var rowNode = settings.aoData[dataIndex] && settings.aoData[dataIndex].nTr;
        return !!(rowNode && rowNode.querySelector('.badge-violation, .badge-warning'));
    });

    /* Wire .filter-toggle checkboxes inside DT sections */
    document.querySelectorAll('.filter-toggle').forEach(function(cb) {
        var section = cb.closest('section');
        if (!section) return;
        var dtTable = section.querySelector('table[id^="dt-"]');
        if (!dtTable) return;
        var tid = dtTable.id;
        window.__dtFilterActive[tid] = cb.checked;
        cb.addEventListener('change', function() {
            window.__dtFilterActive[tid] = cb.checked;
            $('#' + tid).DataTable().draw();
        });
    });

    /* ---------------------------------------------------------------
       DataTables initialization
    --------------------------------------------------------------- */
    {% if calc_options.run_voltage and voltage %}
    var dtVoltage = $('#dt-voltage').DataTable({
        pageLength: 25,
        order: [[3, 'asc']],
        language: { search: 'Node search:' },
        columnDefs: [{ orderable: false, targets: 5 }],
        drawCallback: function() {
            /* Re-highlight navigated row after each draw */
            if (window.__pendingNavRow) {
                _highlightRow(window.__pendingNavRow.tableId, window.__pendingNavRow.name);
            }
        }
    });
    if (window.__dtFilterActive['dt-voltage']) dtVoltage.draw();
    {% endif %}

    {% if calc_options.run_thermal and loading %}
    var dtThermal = $('#dt-thermal').DataTable({
        pageLength: 25,
        order: [[2, 'desc']],
        columnDefs: [{ orderable: false, targets: [2, 5] }],
        drawCallback: function() {
            if (window.__pendingNavRow) {
                _highlightRow(window.__pendingNavRow.tableId, window.__pendingNavRow.name);
            }
        }
    });
    if (window.__dtFilterActive['dt-thermal']) dtThermal.draw();
    {% endif %}

    {% if calc_options.run_n1 and n1 %}
    var dtN1 = $('#dt-n1').DataTable({
        pageLength: 25,
        order: [[3, 'desc']],
        columnDefs: [{ orderable: false, targets: [2, 6, 7] }]
    });
    if (window.__dtFilterActive['dt-n1']) dtN1.draw();
    {% endif %}

    /* ---------------------------------------------------------------
       Row navigation — jump from critical elements to table rows
    --------------------------------------------------------------- */
    function _highlightRow(tableId, elementName) {
        window.__pendingNavRow = null;
        var rows = document.querySelectorAll('#' + tableId + ' tbody tr');
        rows.forEach(function(row) {
            var cell = row.querySelector('td:first-child');
            if (cell && cell.textContent.trim() === elementName) {
                row.classList.add('row-nav-highlight');
                row.scrollIntoView({ behavior: 'smooth', block: 'center' });
                setTimeout(function() { row.classList.remove('row-nav-highlight'); }, 2400);
            }
        });
    }

    window.navigateToRow = function(elementName, tableType) {
        var tableId = tableType === 'voltage'  ? 'dt-voltage'
                    : tableType === 'thermal'  ? 'dt-thermal'
                    : tableType === 'n1'       ? 'dt-n1'
                    : null;
        if (!tableId || typeof $ === 'undefined' || !$.fn.dataTable.isDataTable('#' + tableId)) return;

        var dt = $('#' + tableId).DataTable();
        /* Find row and page */
        var targetPage = null;
        dt.rows().every(function() {
            var node = this.node();
            var cell = node && node.querySelector('td:first-child');
            if (cell && cell.textContent.trim() === elementName) {
                var pageLen = dt.page.len();
                targetPage = Math.floor(this.index() / pageLen);
                return false;
            }
        });

        if (targetPage !== null) {
            window.__pendingNavRow = { tableId: tableId, name: elementName };
            dt.page(targetPage).draw('page');
            setTimeout(function() { _highlightRow(tableId, elementName); }, 250);
        }
    };
});
</script>

</body>
</html>
