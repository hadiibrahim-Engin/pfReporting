<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>De-Energization Assessment - {{ info.date }} {{ info.time }}</title>
    <style>{{ css }}</style>
</head>
<body>
<div class="report">

    {% include 'partials/header.html.j2' %}
    {% include 'partials/overview_board.html.j2' %}
    {% include 'partials/executive_summary.html.j2' %}
    {% include 'partials/ampel.html.j2' %}

    <!-- Global Search -->
    <div class="search-bar">
        <label for="global-search">Search:</label>
        <input type="text" id="global-search" placeholder="Node name, element …" autocomplete="off">
        <span id="search-count"></span>
    </div>

    {% include 'partials/switched.html.j2' %}
    {% include 'partials/n1.html.j2' %}
    {% include 'partials/loadflow.html.j2' %}
    {% include 'partials/statistics.html.j2' %}
    {% include 'partials/qds_info.html.j2' %}

    {% set v_total = voltage | length %}
    {% set t_total = loading | length %}
    {% set ns = namespace(qds_series=0) %}
    {% if ts_data and not ts_data.is_empty() %}
        {% for sec in ts_data.sections.values() %}
            {% set ns.qds_series = ns.qds_series + (sec | length) %}
        {% endfor %}
    {% endif %}

    {% set has_tabs = calc_options.run_voltage or calc_options.run_thermal or (calc_options.run_qds and ts_data and not ts_data.is_empty()) %}
    {% set first_tab = 'tab-voltage' if calc_options.run_voltage else ('tab-thermal' if calc_options.run_thermal else 'tab-qds') %}
    {% if has_tabs %}
    <div class="glass-tabs" role="tablist" aria-label="Report Tabs">
        {% if calc_options.run_voltage %}
        <button class="glass-tab {% if first_tab == 'tab-voltage' %}active{% endif %}" type="button" data-tab="tab-voltage" role="tab" aria-selected="{% if first_tab == 'tab-voltage' %}true{% else %}false{% endif %}">
            Spannungsbandprüfung
            <span class="tab-count">{{ v_total }}</span>
        </button>
        {% endif %}
        {% if calc_options.run_thermal %}
        <button class="glass-tab {% if first_tab == 'tab-thermal' %}active{% endif %}" type="button" data-tab="tab-thermal" role="tab" aria-selected="{% if first_tab == 'tab-thermal' %}true{% else %}false{% endif %}">
            Thermische Auslastung
            <span class="tab-count">{{ t_total }}</span>
        </button>
        {% endif %}
        {% if calc_options.run_qds and ts_data and not ts_data.is_empty() %}
        <button class="glass-tab {% if first_tab == 'tab-qds' %}active{% endif %}" type="button" data-tab="tab-qds" role="tab" aria-selected="{% if first_tab == 'tab-qds' %}true{% else %}false{% endif %}">
            Quasi-Dynamik – nur kritisch
            <span class="tab-count">{{ ns.qds_series }}</span>
        </button>
        {% endif %}
    </div>

    <div class="tab-panels">
        {% if calc_options.run_voltage %}
        <div class="tab-panel {% if first_tab == 'tab-voltage' %}active{% endif %}" data-tab="tab-voltage" role="tabpanel">
            {% include 'partials/voltage.html.j2' %}
        </div>
        {% endif %}
        {% if calc_options.run_thermal %}
        <div class="tab-panel {% if first_tab == 'tab-thermal' %}active{% endif %}" data-tab="tab-thermal" role="tabpanel">
            {% include 'partials/thermal.html.j2' %}
        </div>
        {% endif %}
        {% if calc_options.run_qds and ts_data and not ts_data.is_empty() %}
        <div class="tab-panel {% if first_tab == 'tab-qds' %}active{% endif %}" data-tab="tab-qds" role="tabpanel">
            {% include 'partials/timeseries.html.j2' %}
        </div>
        {% endif %}
    </div>
    {% endif %}
    {% include 'partials/footer.html.j2' %}

</div>

<!-- Vendor JS (inline) -->
<script>{{ vendor_js.hammer }}</script>
<script>{{ vendor_js.chart }}</script>
<script>{{ vendor_js.zoom }}</script>

<!-- Chart data -->
<script>window.__chartData = {{ chart_data_json }};</script>

<!-- Application logic -->
<script>{{ scripts }}</script>
</body>
</html>
