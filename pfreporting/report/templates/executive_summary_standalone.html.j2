<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Executive Summary &mdash; {{ info.project }} &mdash; {{ info.date }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        {{ css }}
        @media print {
            * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            @page { margin: 1.5cm; }
        }
    </style>
</head>
<body class="bg-white text-slate-800 font-sans antialiased p-8 max-w-4xl mx-auto">

{# ---- Header ---- #}
{% set icon_map = {'green': '✅', 'amber': '⚠️', 'red': '❌'} %}
{% set verdict_bg = {'green': 'bg-emerald-50 border-emerald-300 text-emerald-800',
                     'amber': 'bg-amber-50 border-amber-300 text-amber-800',
                     'red':   'bg-red-50 border-red-300 text-red-800'} %}

<div class="flex justify-between items-start mb-6 pb-4 border-b border-slate-200">
    <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-1">Executive Summary — Freischaltbewertung</p>
        <h1 class="text-2xl font-bold text-slate-900">{{ info.project }}</h1>
        <p class="text-sm text-slate-500 mt-0.5">{{ info.study_case }} &mdash; {{ info.date }} {{ info.time }}</p>
    </div>
    <div class="text-right text-xs text-slate-400">
        <p>Generated: {{ info.date }}</p>
    </div>
</div>

{# ---- Verdict Banner ---- #}
<div class="rounded-xl border p-5 mb-6 flex items-start gap-4 {{ verdict_bg[ampel.color] }}">
    <span class="text-4xl leading-none flex-shrink-0 mt-0.5">{{ icon_map[ampel.color] }}</span>
    <div>
        <p class="text-xl font-extrabold tracking-tight leading-tight">{{ ampel.verdict }}</p>
        <ul class="mt-2 text-sm space-y-0.5 list-disc list-inside opacity-90">
            {% for f in ampel.findings %}<li>{{ f }}</li>{% endfor %}
        </ul>
    </div>
</div>

{# ---- KPI Hero Grid ---- #}
{% set v_viol = overall.voltage_violations %}
{% set t_viol = overall.thermal_violations %}
{% set n1_viol = overall.n1_violations %}

<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
    <div class="rounded-2xl p-5 border-2 {% if overall.total_violations > 0 %}bg-red-50 border-red-300{% else %}bg-emerald-50 border-emerald-300{% endif %}">
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-1">Total Violations</p>
        <p class="text-6xl font-black leading-none {% if overall.total_violations > 0 %}text-red-600{% else %}text-emerald-600{% endif %}">
            {{ overall.total_violations }}
        </p>
    </div>
    <div class="rounded-2xl p-5 bg-white border border-slate-200 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-1">Voltage</p>
        <p class="text-5xl font-extrabold leading-none {% if v_viol > 0 %}text-red-600{% else %}text-slate-300{% endif %}">{{ v_viol }}</p>
        <p class="text-xs text-slate-400 mt-1">violations</p>
    </div>
    <div class="rounded-2xl p-5 bg-white border border-slate-200 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-1">Thermal</p>
        <p class="text-5xl font-extrabold leading-none {% if t_viol > 0 %}text-red-600{% else %}text-slate-300{% endif %}">{{ t_viol }}</p>
        <p class="text-xs text-slate-400 mt-1">violations</p>
    </div>
    <div class="rounded-2xl p-5 bg-white border border-slate-200 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-1">N-1</p>
        <p class="text-5xl font-extrabold leading-none {% if n1_viol > 0 %}text-red-600{% else %}text-slate-300{% endif %}">{{ n1_viol }}</p>
        <p class="text-xs text-slate-400 mt-1">violations</p>
    </div>
</div>

{# ---- Secondary Metrics ---- #}
<div class="grid grid-cols-3 sm:grid-cols-6 gap-3 mb-6">
    <div class="rounded-xl bg-slate-50 border border-slate-200 p-3 text-center">
        <div class="text-2xl font-bold text-slate-800">{{ overall.total_nodes }}</div>
        <div class="text-xs text-slate-500 uppercase tracking-wide mt-0.5">Nodes</div>
    </div>
    <div class="rounded-xl bg-slate-50 border border-slate-200 p-3 text-center">
        <div class="text-2xl font-bold text-slate-800">{{ overall.total_elements }}</div>
        <div class="text-xs text-slate-500 uppercase tracking-wide mt-0.5">Elements</div>
    </div>
    <div class="rounded-xl bg-slate-50 border border-slate-200 p-3 text-center">
        <div class="text-2xl font-bold text-slate-800">{{ overall.total_n1 }}</div>
        <div class="text-xs text-slate-500 uppercase tracking-wide mt-0.5">N-1 Cases</div>
    </div>
    {% if lf %}
    <div class="rounded-xl bg-slate-50 border border-slate-200 p-3 text-center">
        <div class="text-xl font-bold text-slate-800">{{ "%.1f"|format(lf.total_load_mw) }}</div>
        <div class="text-xs text-slate-500 uppercase tracking-wide mt-0.5">Load [MW]</div>
    </div>
    <div class="rounded-xl bg-slate-50 border border-slate-200 p-3 text-center">
        <div class="text-xl font-bold text-slate-800">{{ "%.1f"|format(lf.total_gen_mw) }}</div>
        <div class="text-xs text-slate-500 uppercase tracking-wide mt-0.5">Gen [MW]</div>
    </div>
    <div class="rounded-xl bg-slate-50 border border-slate-200 p-3 text-center">
        <div class="text-xl font-bold text-slate-800">{{ "%.2f"|format(lf.losses_mw) }}</div>
        <div class="text-xs text-slate-500 uppercase tracking-wide mt-0.5">Losses [MW]</div>
    </div>
    {% endif %}
</div>

{# ---- Critical Elements ---- #}
{% if top_voltage_violations or top_loading_violations %}
<div class="border border-red-100 rounded-xl p-5 bg-red-50 mb-6">
    <h3 class="text-xs font-bold text-red-700 uppercase tracking-widest mb-4">Critical Elements</h3>
    <div class="grid sm:grid-cols-2 gap-5">
        {% if top_voltage_violations %}
        <div>
            <p class="text-xs font-semibold text-slate-600 mb-2">Voltage Violations</p>
            {% for r in top_voltage_violations %}
            <div class="flex justify-between items-center py-1.5 border-b border-red-100 text-xs gap-3">
                <span class="truncate text-slate-700 font-medium">{{ r.node }}</span>
                <span class="badge-violation flex-shrink-0">{{ "%.4f"|format(r.u_pu) }} p.u.</span>
            </div>
            {% endfor %}
        </div>
        {% endif %}
        {% if top_loading_violations %}
        <div>
            <p class="text-xs font-semibold text-slate-600 mb-2">Thermal Violations</p>
            {% for r in top_loading_violations %}
            <div class="flex justify-between items-center py-1.5 border-b border-red-100 text-xs gap-3">
                <span class="truncate text-slate-700 font-medium">{{ r.name }}</span>
                <span class="badge-violation flex-shrink-0">{{ "%.1f"|format(r.loading_pct) }}%</span>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</div>
{% endif %}

{# ---- Calculation Settings ---- #}
<div class="border border-slate-200 rounded-xl p-5 mb-6">
    <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3">Calculation Parameters</h3>
    <dl class="grid sm:grid-cols-2 gap-x-8 gap-y-1 text-xs">
        <div class="flex justify-between py-1 border-b border-slate-100">
            <dt class="text-slate-500">Method</dt>
            <dd class="font-medium text-slate-700">Newton-Raphson, AC, pos. seq.</dd>
        </div>
        {% if calc_options.run_voltage %}
        <div class="flex justify-between py-1 border-b border-slate-100">
            <dt class="text-slate-500">Voltage Violation</dt>
            <dd class="font-semibold text-red-600">&le; {{ vcfg.lower_violation }} / &ge; {{ vcfg.upper_violation }} p.u.</dd>
        </div>
        {% endif %}
        {% if calc_options.run_thermal %}
        <div class="flex justify-between py-1 border-b border-slate-100">
            <dt class="text-slate-500">Thermal Violation</dt>
            <dd class="font-semibold text-red-600">&ge; {{ tcfg.violation_pct }}%</dd>
        </div>
        {% endif %}
        {% if calc_options.run_n1 %}
        <div class="flex justify-between py-1 border-b border-slate-100">
            <dt class="text-slate-500">N-1 Max. Loading</dt>
            <dd class="font-semibold text-red-600">&gt; {{ n1cfg.max_loading_pct }}%</dd>
        </div>
        {% endif %}
    </dl>
</div>

{# ---- Footer / Disclaimer ---- #}
<div class="pt-4 border-t border-slate-200 text-xs text-slate-400">
    <p>This report was generated automatically by <strong>pfreporting</strong>. Results are based on static load-flow calculations within DIgSILENT PowerFactory. Values are indicative — always verify critical decisions with a qualified network engineer.</p>
</div>

</body>
</html>
